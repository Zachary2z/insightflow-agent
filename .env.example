# Runtime secrets. Keep real values only in an ignored local .env or a real
# deployment secret manager; never put them in NEXT_PUBLIC_* or Docker build args.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Public/non-sensitive Compose and provider configuration.
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000
NEXT_PUBLIC_API_BASE=http://localhost:8000
INSIGHTFLOW_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
INSIGHTFLOW_PRODUCT_LIVE_MODE=0

# Local development/test configuration outside the base Compose contract.
INSIGHTFLOW_LIVE_DEEPSEEK_TESTS=0
INSIGHTFLOW_DB_PATH=data/ecommerce.db
INSIGHTFLOW_METRICS_PATH=data/metrics.yaml
INSIGHTFLOW_TRACE_DIR=logs/traces
INSIGHTFLOW_MAX_ROWS=100
INSIGHTFLOW_SQL_TIMEOUT_SECONDS=5
