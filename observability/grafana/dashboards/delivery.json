    {"id": 1, "title": "Report Generation", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0}, "targets": [{"refId": "A", "expr": "sum by (status) (rate(insightflow_report_generations_total[5m]))", "legendFormat": "{{status}}"}]},
    {"id": 2, "title": "Word Export", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0}, "targets": [{"refId": "A", "expr": "sum by (format, status) (rate(insightflow_document_exports_total[5m]))", "legendFormat": "{{format}} / {{status}}"}]},
    {"id": 3, "title": "Feishu Publish", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9}, "targets": [{"refId": "A", "expr": "sum by (platform, status) (rate(insightflow_external_publishes_total[5m]))", "legendFormat": "{{platform}} / {{status}}"}]},
